{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Run JSFL Client",
      "type": "extensionHost",
      "request": "launch",
      "runtimeExecutable": "${execPath}",
      "args": [
        "--extensionDevelopmentPath=${workspaceFolder}/client",
        "--folder-uri=${workspaceFolder}"
      ],
      "outFiles": [
        "${workspaceFolder}/client/out/**/*.js"
      ],
      "preLaunchTask": "build:all"
    }
  ]
}
